# APP_SECRET: 32+ random chars, used to sign session cookies. Keep secret.
APP_SECRET=
# APP_PASSWORD: the single login password.
APP_PASSWORD=
# COOKIE_SECURE: cookies default to Secure (HTTPS-only). Set 'false' ONLY for
# local http dev. In production (behind Nginx TLS) omit this or set it to true.
COOKIE_SECURE=false
